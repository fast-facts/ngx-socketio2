{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base"
    ],
    "minimumReleaseAge": "14 days",
    "schedule": [
        "before 4am"
    ],
    "timezone": "America/New_York",
    "prCreation": "immediate",
    "labels": [
        "dependencies"
    ],
    "rangeStrategy": "bump",
    "automerge": true,
    "automergeType": "pr",
    "packageRules": [
        {
            "matchManagers": [
                "github-actions"
            ],
            "matchDepTypes": [
                "uses-with"
            ],
            "matchDepNames": [
                "node"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "enabled": false
        },
        {
            "matchDepTypes": [
                "engines"
            ],
            "matchPackageNames": [
                "node"
            ],
            "enabled": false
        },
        {
            "matchPackageNames": [
                "@angular*"
            ],
            "enabled": false
        },
        {
            "matchPackageNames": [
                "ng-packagr"
            ],
            "enabled": false
        },
        {
            "matchPackageNames": [
                "typescript"
            ],
            "matchCurrentVersion": ">=5.7.0",
            "enabled": false
        },
        {
            "groupName": "typescript and eslint",
            "matchPackageNames": [
                "*typescript*",
                "*eslint*"
            ]
        },
        {
            "groupName": "karma",
            "matchPackageNames": [
                "*karma*"
            ]
        },
        {
            "groupName": "types",
            "matchPackageNames": [
                "@types/*"
            ]
        }
    ]
}